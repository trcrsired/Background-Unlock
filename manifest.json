{
  "manifest_version": 3,
  "name": "Background Unlock",
  "icons": { "256": "logo.png" },
  "version": "2",
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.vimeo.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://*.youtube.com/*",
        "https://*.youtube-nocookie.com/*",
        "https://*.vimeo.com/*"
      ]
    }
  ]
}
